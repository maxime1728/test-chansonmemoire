      { "type": "text", "track": 4, "time": 3.5, "duration": 3.4, "text": "Dans la lumière douce du matin", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
