      { "type": "text", "track": 4, "time": 10.3, "duration": 3.4, "text": "Les étés au chalet, les chansons", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
        "animations": [ { "time": 0, "duration": 0.8, "easing": "quadratic-out", "type": "fade" }, { "time": "end", "duration": 0.8, "easing": "quadratic-in", "type": "fade", "reversed": true } ] },
      { "type": "text", "track": 4, "time": 13.7, "duration": 3.4, "text": "Et ton rire qui portait nos saisons", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
        "animations": [ { "time": 0, "duration": 0.8, "easing": "quadratic-out", "type": "fade" }, { "time": "end", "duration": 0.8, "easing": "quadratic-in", "type": "fade", "reversed": true } ] },
      { "type": "text", "track": 4, "time": 17.1, "duration": 3.4, "text": "Tu vis encore dans chaque mélodie", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
        "animations": [ { "time": 0, "duration": 0.8, "easing": "quadratic-out", "type": "fade" }, { "time": "end", "duration": 0.8, "easing": "quadratic-in", "type": "fade", "reversed": true } ] },
      { "type": "text", "track": 4, "time": 20.5, "duration": 3.4, "text": "Dans chaque mot que le vent nous confie", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
        "animations": [ { "time": 0, "duration": 0.8, "easing": "quadratic-out", "type": "fade" }, { "time": "end", "duration": 0.8, "easing": "quadratic-in", "type": "fade", "reversed": true } ] },
      { "type": "text", "track": 4, "time": 23.9, "duration": 3.4, "text": "Pour toujours, gravée dans nos cœurs", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
        "animations": [ { "time": 0, "duration": 0.8, "easing": "quadratic-out", "type": "fade" }, { "time": "end", "duration": 0.8, "easing": "quadratic-in", "type": "fade", "reversed": true } ] },
      { "type": "text", "track": 4, "time": 27.3, "duration": 3.4, "text": "Ta mémoire est notre douceur", "font_family": "EB Garamond", "font_weight": "400", "font_size": 44, "fill_color": "#F5F0EA", "line_height": "128%", "width": "86%", "x_alignment": "50%", "y_alignment": "50%",
