<style>
  :root{
    color-scheme:light;
    --paper:#FAF6EF; --paper-2:#FFFDF8; --card:#FFFFFF;
    --ink:#241D2E; --plum:#4C3260; --plum-soft:#6A4B80;
    --gold:#9C7A2E; --gold-soft:#E7D3A6;
    --muted:#615969; --line:#E9E1D5;
    --shadow:0 1px 2px rgba(36,29,46,.05), 0 14px 36px -18px rgba(76,50,96,.20);
    --r:18px;
  }
  *{box-sizing:border-box}
  html{-webkit-text-size-adjust:100%; color-scheme:light; background:var(--paper)}
  body{
    margin:0; background:var(--paper); color:var(--ink);
    font-family:"Mulish",system-ui,sans-serif; font-size:17px; line-height:1.55;
    padding-bottom:152px; /* room for dock (cookie + CTA) */
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:500px; margin:0 auto; padding:0 22px}
  h1,h2,h3{font-family:"Fraunces",Georgia,serif; font-weight:500; letter-spacing:-.01em; line-height:1.08; margin:0}
  p{margin:0}
  a{color:inherit}
  .eyebrow{font-size:12.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--gold); font-weight:700}
  .muted{color:var(--muted)}

  /* ---- dev hook switcher (NOT part of the design — preview tool) ---- */
  .dev{position:sticky; top:0; z-index:60; background:#2B2333; color:#EFE9DF;
    font-size:12px; display:flex; gap:8px; align-items:center; justify-content:center;
    padding:7px 10px; flex-wrap:wrap}
  .dev span{opacity:.65; letter-spacing:.04em}
  .dev button{font:inherit; background:transparent; color:#EFE9DF; border:1px solid #5c5167;
    border-radius:999px; padding:4px 11px; cursor:pointer}
  .dev button[aria-pressed="true"]{background:var(--gold); border-color:var(--gold); color:#1f1828; font-weight:700}

  /* ---- top bar ---- */
  header.bar{padding:18px 0 4px}
  .brand{display:flex; align-items:center; gap:9px}
  .mark{width:30px;height:30px;flex:0 0 auto}
  .brand .nm{font-family:"Fraunces",serif; font-weight:600; letter-spacing:.12em; font-size:15px; text-transform:uppercase}
  .qc{display:inline-flex; align-items:center; gap:6px; margin-top:14px; font-size:13px; color:var(--plum-soft); font-weight:600}
  .qc svg{flex:0 0 auto}

  /* ---- hero ---- */
  .hero{padding:8px 0 6px}
  .hero h1{font-size:40px; margin-top:10px}
  .hero h1 .accent{color:var(--plum); font-style:italic; font-weight:400}
  .hero .sub{font-size:18px; color:#4a4350; margin-top:16px; max-width:30ch}

  /* signature: example card w/ waveform */
  .demo{margin:26px 0 10px; background:var(--card); border:1px solid var(--line);
    border-radius:var(--r); padding:16px; box-shadow:var(--shadow); position:relative}
  .demo .tag{position:absolute; top:14px; right:14px; font-size:11px; letter-spacing:.12em;
    text-transform:uppercase; color:var(--muted); background:var(--paper); border:1px solid var(--line);
    border-radius:999px; padding:3px 9px}
  .portrait{display:flex; gap:14px; align-items:center}
  .frame{width:74px;height:84px;flex:0 0 auto;border-radius:10px;overflow:hidden;
    background:linear-gradient(150deg,#6E4F84,#3a2748); display:grid;place-items:center;
    box-shadow:inset 0 0 0 4px #fff, inset 0 0 0 5px var(--line)}
  .frame span{font-family:"Fraunces",serif; color:#E7D3A6; font-size:30px}
  .who .name{font-family:"Fraunces",serif; font-size:21px; font-weight:600}
  .who .dates{font-size:13px; color:var(--muted); margin-top:2px}
  .who .line{font-style:italic; color:var(--plum-soft); font-size:14.5px; margin-top:7px}
  .player{display:flex; align-items:center; gap:13px; margin-top:16px; padding-top:15px; border-top:1px solid var(--line)}
  .play{width:42px;height:42px;flex:0 0 auto;border-radius:999px;border:none;cursor:pointer;
    background:var(--plum); color:#fff; display:grid; place-items:center; box-shadow:0 6px 16px -6px var(--plum)}
  .wave{display:flex; align-items:center; gap:3px; height:34px; flex:1}
  .wave i{display:block; width:3px; border-radius:2px; background:var(--gold-soft); height:30%}
  .wave i.on{background:var(--gold)}
  .playing .wave i{animation:pulse 1.1s ease-in-out infinite}
  @keyframes pulse{0%,100%{transform:scaleY(.45)}50%{transform:scaleY(1)}}
  .ptime{font-size:12px;color:var(--muted);font-variant-numeric:tabular-nums}

  /* CTA + trust */
  .cta{display:flex;flex-direction:column;align-items:center;gap:2px;width:100%;text-align:center;text-decoration:none;
    background:var(--plum); color:#fff;
    padding:13px 18px; border-radius:14px; border:none; cursor:pointer;
    box-shadow:0 12px 26px -10px rgba(76,50,96,.55)}
  .cta:hover{background:#3f2952}
  .cta-main{font-weight:800; font-size:18px; letter-spacing:.01em}
  .cta-sub{font-size:12.5px; font-weight:600; color:#EAD7AB; letter-spacing:.02em}
  .cta .arrow{margin-left:5px}
  .trust{display:flex;flex-wrap:wrap;gap:6px 14px;justify-content:center;margin-top:14px;
    font-size:13px;color:var(--muted)}
  .trust b{color:var(--plum-soft);font-weight:700}
  .trust .dot{color:var(--line)}

  /* sections */
  section{padding:38px 0}
  .rule{height:1px;background:var(--line);margin:0 22px;max-width:456px;margin-left:auto;margin-right:auto}
  .kicker{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:14px}
  h2.title{font-size:27px}

  .steps{list-style:none;padding:0;margin:18px 0 0;display:grid;gap:16px}
  .steps li{display:grid;grid-template-columns:34px 1fr;gap:14px;align-items:start}
  .num{font-family:"Fraunces",serif;font-size:20px;color:var(--gold);font-weight:600;
    border-bottom:2px solid var(--gold-soft);width:30px;text-align:center;line-height:1.3}
  .steps h3{font-size:18px;font-weight:600;margin-bottom:3px}
  .steps p{font-size:15px;color:#544d5e}

  .proof{background:var(--paper-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .stars{color:var(--gold);letter-spacing:3px;font-size:15px}
  .count{font-family:"Fraunces",serif;font-size:23px;font-weight:600;margin:8px 0 2px}
  .quotes{display:grid;gap:14px;margin-top:22px}
  .quote{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 17px}
  .quote p{font-size:15px;font-style:italic;color:#42394e}
  .quote .by{font-style:normal;font-size:13px;color:var(--muted);margin-top:9px;font-weight:600}

  .reassure{display:grid;gap:12px;margin-top:18px}
  .reassure div{display:grid;grid-template-columns:24px 1fr;gap:11px;font-size:15px;color:#4a4350}
  .reassure svg{margin-top:3px;color:var(--gold)}

  details{border-bottom:1px solid var(--line);padding:14px 0}
  summary{font-family:"Fraunces",serif;font-size:17px;font-weight:500;cursor:pointer;list-style:none;
    display:flex;justify-content:space-between;gap:12px;align-items:center}
  summary::-webkit-details-marker{display:none}
  summary .chev{color:var(--plum-soft);transition:transform .2s}
  details[open] summary .chev{transform:rotate(180deg)}
  details p{font-size:15px;color:#544d5e;margin-top:10px}

  footer{padding:30px 0 26px;color:var(--muted);font-size:13px}
  footer .links{display:flex;flex-wrap:wrap;gap:6px 16px;margin-bottom:14px}
  footer a{color:var(--plum-soft);font-weight:600;text-decoration:none}
  footer a:hover{text-decoration:underline}
  .merchant{line-height:1.5}
  .ai-note{margin-top:12px;font-size:12.5px}

  /* dock : pile cookie + CTA, aucun chevauchement */
  .dock{position:fixed;left:0;right:0;bottom:0;z-index:50}
  .sticky{background:rgba(250,246,239,.94);backdrop-filter:blur(10px);border-top:1px solid var(--line);padding:10px 22px calc(12px + env(safe-area-inset-bottom))}
  .sticky .inner{max-width:500px;margin:0 auto}

  /* cookie : ruban mince et clair, AU-DESSUS du CTA */
  .cookie{display:flex;align-items:center;justify-content:center;gap:8px 12px;flex-wrap:wrap;
    max-width:500px;margin:0 auto;padding:7px 16px;font-size:12px;color:var(--muted);
    background:var(--paper-2);border-top:1px solid var(--line)}
  .cookie a{color:var(--plum-soft)}
  .ck-actions{display:flex;gap:7px;flex:0 0 auto}
  .cookie button{font:inherit;font-size:12px;font-weight:700;border-radius:999px;cursor:pointer;
    padding:4px 13px;border:1px solid var(--line);background:transparent;color:var(--plum)}
  .cookie button.acc{background:var(--plum);border-color:var(--plum);color:#fff}
  .cookie.hidden{display:none}

  :focus-visible{outline:2px solid var(--gold);outline-offset:2px;border-radius:6px}
  .reveal{opacity:1;transform:none}
  .js .reveal{opacity:0;transform:translateY(10px)}
  .js .reveal.in{opacity:1;transform:none;transition:opacity .6s ease, transform .6s ease}
  @media (prefers-reduced-motion:reduce){
    .playing .wave i{animation:none}
    .js .reveal{opacity:1;transform:none;transition:none}
  }
  @media(min-width:540px){ .hero h1{font-size:46px} }
</style>
</head>
<body>

<!-- DEV ONLY — outil d'aperçu, retiré en production -->
<nav class="dev" aria-label="Démo développeur">
  <span>Démo dev · hook cliqué sur Facebook :</span>
