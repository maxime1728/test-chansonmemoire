<script>
/* ---- Hook → contenu du hero (le reste de la page ne bouge pas) ---- */
const HOOKS = {
  honorer:{
    eyebrow:"Pour quelqu'un que tu n'oublieras jamais",
    headline:['Sa chanson, prête à écouter ','en 3 minutes'],
    sub:"Tu nous parles d'elle. On compose une chanson originale qui capture qui elle était — pour toujours."
  },
  date:{
    eyebrow:"Pour la date qui approche",
    headline:['Une chanson qui ','lui ressemble'],
    sub:"Sa fête, un anniversaire, le temps des Fêtes… Offre un hommage qui se fait entendre, pas juste une pensée."
  },
  vivante:{
    eyebrow:"Garde leur présence",
    headline:['Garde sa mémoire ','vivante'],
    sub:"Une chanson unique, à écouter et à partager avec ceux que tu aimes, pour que sa voix reste parmi vous."
  }
};
document.body.classList.add('js');
const headline=document.getElementById('headline');
const subhead=document.getElementById('subhead');
const eyebrow=document.getElementById('eyebrow');
function setHook(k){
  const h=HOOKS[k]; if(!h) return;
  headline.innerHTML = h.headline[0] + '<span class="accent">'+h.headline[1]+'</span>';
  subhead.textContent = h.sub;
  eyebrow.textContent = h.eyebrow;
}
/* lit ?h= dans l'URL (transporte par la pub), sinon defaut */
let urlHook=null;
try{ urlHook = new URLSearchParams(location.search).get('h'); }catch(e){}
const start = HOOKS[urlHook] ? urlHook : 'honorer';
setHook(start);
document.querySelectorAll('.dev button').forEach(b=>{
  b.setAttribute('aria-pressed', b.dataset.hook===start);
  b.addEventListener('click',()=>{
    document.querySelectorAll('.dev button').forEach(x=>x.setAttribute('aria-pressed','false'));
    b.setAttribute('aria-pressed','true');
    setHook(b.dataset.hook);
  });
});

/* ---- waveform (visuel) ---- */
const wave=document.getElementById('wave');
const H=[35,60,40,80,55,95,50,70,45,85,60,40,75,50,65,38,72,48,90,55,42,68,52,80,46];
H.forEach((h,i)=>{const i2=document.createElement('i');i2.style.height=h+'%';if(i<11)i2.classList.add('on');wave.appendChild(i2);});
const demo=document.getElementById('player').closest('.demo');
const play=document.getElementById('play');
const icon=document.getElementById('playIcon');
let playing=false;
play.addEventListener('click',()=>{
  playing=!playing; demo.classList.toggle('playing',playing);
  icon.innerHTML = playing ? '<rect x="4" y="3" width="3" height="10"/><rect x="9" y="3" width="3" height="10"/>' : '<path d="M4 3.2 13 8l-9 4.8V3.2Z"/>';
  play.setAttribute('aria-label', playing?"Mettre en pause":"Écouter l'aperçu de l'exemple");
});

/* ---- cookie consent : le pixel ne se déclenche qu'après acceptation ---- */
const cookie=document.getElementById('cookie');
function closeCookie(consent){ cookie.classList.add('hidden'); /* si consent: declencher Pixel + CAPI ici */ }
document.getElementById('ckAccept').addEventListener('click',()=>closeCookie(true));
document.getElementById('ckRefuse').addEventListener('click',()=>closeCookie(false));

/* ---- reveals ---- */
const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}}),{threshold:.15});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
</body>
</html>
