{
  "name": "chansonmemoire-functions",
  "version": "1.0.0",
  "private": true,
  "description": "Dépendances des Netlify Functions de Chanson Mémoire. (Le reste du site = HTML/JS statique sans build.)",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:ts": "node --import tsx --test tests-ts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@sentry/node": "^8.47.0",
    "drizzle-orm": "^0.45.2",
    "pdfkit": "^0.15.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
