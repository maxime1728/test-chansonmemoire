<!DOCTYPE html>
<html lang="fr-CA">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Votre chanson est prête — Chanson Mémoire</title>
  <meta name="description" content="Écoute l'aperçu de ta chanson personnalisée avant de l'obtenir au complet." />
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..500&family=Mulish:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
/* ============================================================
   Chanson Mémoire — feuille de style partagée
   Palette : prune profonde + lavande + lueur de chandelle (ambre)
   Type : Fraunces (titres) · Mulish (texte)
   ============================================================ */

:root {
  --plum: #4a3b57;
  --plum-deep: #2e2238;
  --ink: #2a2330;
  --muted: #6b6175;
  --lavender-bg: #f5f1f8;
  --lavender-soft: #ece6f2;
  --line: #e3dceb;
  --candle: #c39a52;
  --candle-soft: #ecdcbd;
  --white: #ffffff;
  --card: #fbfafc;
  --radius: 18px;
  --radius-pill: 999px;
  --maxw: 680px;
  --shadow: 0 10px 30px rgba(46, 34, 56, 0.08);
  --shadow-soft: 0 4px 14px rgba(46, 34, 56, 0.06);
}

* { box-sizing: border-box; }

html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

body {
  margin: 0;
  font-family: "Mulish", system-ui, -apple-system, sans-serif;
  color: var(--ink);
  background: var(--lavender-bg);
  line-height: 1.6;
  font-size: 17px;
}

h1, h2, h3 {
  font-family: "Fraunces", Georgia, serif;
  color: var(--plum-deep);
  line-height: 1.18;
  font-weight: 600;
  margin: 0 0 0.5em;
  letter-spacing: -0.01em;
}
h1 { font-size: clamp(2rem, 7vw, 3.1rem); }
h2 { font-size: clamp(1.5rem, 5vw, 2.1rem); }
h3 { font-size: 1.2rem; }
p { margin: 0 0 1em; }
a { color: var(--plum); }

img { max-width: 100%; height: auto; display: block; }

/* ---- layout ---- */
.wrap { width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 22px; }
.section { padding: 56px 0; }
.section--tight { padding: 36px 0; }
.section--soft { background: var(--lavender-soft); }
.center { text-align: center; }
.eyebrow {
  font-family: "Mulish", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 0.72rem;
  font-weight: 800;
  color: var(--candle);
  margin: 0 0 14px;
}
.lede { font-size: 1.12rem; color: var(--muted); }
.fineprint { font-size: 0.82rem; color: var(--muted); }

/* ---- candle divider (signature) ---- */
.flame {
  width: 22px; height: 30px; margin: 30px auto; position: relative;
}
.flame::before {
  content: ""; position: absolute; inset: 0; margin: auto;
  width: 10px; height: 16px; border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  background: linear-gradient(180deg, var(--candle-soft), var(--candle));
  box-shadow: 0 0 18px 4px rgba(195, 154, 82, 0.45);
}
.flame::after {
  content: ""; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%);
  width: 2px; height: 10px; background: var(--plum-deep); opacity: .5;
}

/* ---- header ---- */
.site-header {
  position: sticky; top: 0; z-index: 40;
  background: rgba(245, 241, 248, 0.92);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--line);
}
.site-header .wrap { display: flex; align-items: center; justify-content: space-between; height: 62px; }
.brand { display: flex; align-items: center; gap: 10px; font-family: "Fraunces", serif; font-weight: 600; color: var(--plum-deep); font-size: 1.15rem; text-decoration: none; }
.brand img { height: 30px; width: auto; }
.nav { display: none; gap: 26px; }
.nav a { color: var(--plum-deep); text-decoration: none; font-size: 0.92rem; font-weight: 600; opacity: .82; }
.nav a:hover { opacity: 1; color: var(--candle); }
@media (min-width: 760px) { .nav { display: flex; } }

/* ---- buttons ---- */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: var(--plum); color: #fff; text-decoration: none;
  font-weight: 800; font-size: 1.02rem;
  padding: 16px 30px; border-radius: var(--radius-pill); border: 0; cursor: pointer;
  box-shadow: var(--shadow-soft); transition: transform .15s ease, background .15s ease;
  text-align: center;
}
.btn:hover { background: var(--plum-deep); transform: translateY(-1px); }
.btn:focus-visible { outline: 3px solid var(--candle); outline-offset: 3px; }
.btn--block { display: flex; width: 100%; }
.btn--lg { padding: 18px 34px; font-size: 1.08rem; }
.btn-note { font-size: 0.82rem; color: var(--muted); margin-top: 10px; text-align: center; }

/* ---- hero ---- */
.hero { position: relative; overflow: hidden; padding: 52px 0 40px; text-align: center; }
.hero::before {
  content: ""; position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
  width: 420px; height: 420px; border-radius: 50%;
  background: radial-gradient(circle, rgba(195,154,82,0.20), rgba(195,154,82,0) 70%);
  pointer-events: none;
}
.hero .ai-line { font-size: 0.92rem; color: var(--muted); max-width: 30em; margin: 0 auto 22px; }
.hero .risk { font-family: "Fraunces", serif; font-style: italic; color: var(--plum); font-size: 1.1rem; margin: 0 0 24px; }

/* ---- keepsake audio card ---- */
.keepsake {
  background: var(--white); border: 1px solid var(--line); border-radius: var(--radius);
  padding: 20px; box-shadow: var(--shadow); margin: 26px auto 0; max-width: 460px;
}
.keepsake .ks-title { font-family: "Fraunces", serif; color: var(--plum-deep); font-weight: 600; margin-bottom: 4px; }
.keepsake .ks-sub { font-size: 0.85rem; color: var(--muted); margin-bottom: 14px; }
audio { width: 100%; }

/* ---- steps (a real sequence → numbered) ---- */
.steps { display: grid; gap: 18px; margin-top: 28px; }
.step { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px; }
.step .n {
  font-family: "Fraunces", serif; font-size: 1.1rem; font-weight: 600; color: var(--candle);
  display: inline-flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; border-radius: 50%; border: 1.5px solid var(--candle-soft);
  margin-bottom: 14px;
}
.step h3 { margin-bottom: 6px; }
.step p { margin: 0; color: var(--muted); }

/* ---- use-case grid ---- */
.cards { display: grid; gap: 16px; margin-top: 26px; }
@media (min-width: 620px) { .cards { grid-template-columns: 1fr 1fr; } }
.card { background: var(--white); border: 1px solid var(--line); border-radius: var(--radius); padding: 22px; }
.card h3 { color: var(--plum); margin-bottom: 6px; }
.card p { margin: 0; color: var(--muted); font-size: 0.96rem; }

/* ---- included / value stack ---- */
.included { background: var(--white); border: 1px solid var(--line); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow-soft); }
.included ul { list-style: none; padding: 0; margin: 0; }
.included li { display: flex; gap: 12px; align-items: flex-start; padding: 9px 0; border-bottom: 1px solid var(--line); }
.included li:last-child { border-bottom: 0; }
.included .check { color: var(--candle); flex: 0 0 auto; margin-top: 3px; }
.compare { font-family: "Fraunces", serif; font-style: italic; color: var(--plum); margin: 18px 0 0; }

/* ---- price block (preview) ---- */
.price { text-align: center; }
.price .amount { font-family: "Fraunces", serif; font-size: 2.6rem; color: var(--plum-deep); font-weight: 600; }
.price .tax { font-size: 0.9rem; color: var(--muted); }

/* ---- testimonials ---- */
.quotes { display: grid; gap: 16px; margin-top: 26px; }
.quote { background: var(--white); border: 1px solid var(--line); border-left: 3px solid var(--candle); border-radius: var(--radius); padding: 22px; }
.quote p { font-size: 1rem; color: var(--ink); margin: 0 0 10px; }
.quote .who { font-weight: 800; color: var(--plum-deep); font-size: 0.9rem; }
.placeholder-note { background: #fff7e8; border: 1px dashed var(--candle); border-radius: 12px; padding: 14px; font-size: 0.86rem; color: #7a5b1d; }

/* ---- FAQ ---- */
.faq { margin-top: 24px; }
.faq details { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 4px 18px; margin-bottom: 12px; }
.faq summary { cursor: pointer; font-weight: 800; color: var(--plum-deep); padding: 14px 0; list-style: none; }
.faq summary::-webkit-details-marker { display: none; }
.faq summary::after { content: "+"; float: right; color: var(--candle); font-weight: 800; }
.faq details[open] summary::after { content: "–"; }
.faq details p { color: var(--muted); margin: 0 0 14px; }

/* ---- reassurance row ---- */
.reassure { display: flex; flex-wrap: wrap; gap: 18px; justify-content: center; margin-top: 22px; }
.reassure div { font-size: 0.9rem; color: var(--muted); display: flex; align-items: center; gap: 8px; }

/* ---- preview header badge ---- */
.ready-badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--lavender-soft); color: var(--plum-deep); font-weight: 800;
  border-radius: var(--radius-pill); padding: 10px 22px; margin-bottom: 22px; font-size: 0.95rem;
}

/* ---- footer ---- */
.site-footer { background: var(--plum-deep); color: #d9cfe4; padding: 40px 0; margin-top: 20px; }
.site-footer a { color: #fff; text-decoration: none; opacity: .9; }
.site-footer a:hover { opacity: 1; text-decoration: underline; }
.site-footer .legal { display: flex; flex-wrap: wrap; gap: 8px 18px; margin: 16px 0; font-size: 0.9rem; }
.site-footer .copy { font-size: 0.82rem; opacity: .7; }

/* ---- consent banner ---- */
.consent {
  position: fixed; left: 14px; right: 14px; bottom: 14px; z-index: 60;
  background: var(--white); border: 1px solid var(--line); border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 18px 20px; max-width: 640px; margin: 0 auto;
  display: none;
}
.consent.show { display: block; }
.consent p { font-size: 0.88rem; color: var(--ink); margin: 0 0 12px; }
.consent .row { display: flex; gap: 10px; flex-wrap: wrap; }
.consent .btn { padding: 11px 22px; font-size: 0.92rem; }
.consent .btn--ghost { background: transparent; color: var(--plum); border: 1.5px solid var(--line); box-shadow: none; }
.consent .btn--ghost:hover { background: var(--lavender-soft); transform: none; }

/* ---- reveal animation ---- */
.reveal { opacity: 0; transform: translateY(14px); transition: opacity .6s ease, transform .6s ease; }
.reveal.in { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; transition: none; }
  html { scroll-behavior: auto; }
}

</style>
</head>
<body>

  <header class="site-header">
    <div class="wrap">
      <a class="brand" href="/">
        <img src="https://images.leadconnectorhq.com/image/f_webp/q_80/r_1200/u_https://assets.cdn.filesafe.space/D9XKzBleItsO8ARBbCWz/media/ddd50b3e-b382-4b9b-b02b-d18d67e2998e.png" alt="Chanson Mémoire" />
      </a>
